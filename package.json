    "type": "git",
    "url": "git+https://github.com/mahmudunnabikajal/niftycli.git"
  },
  "bugs": {
    "url": "https://github.com/mahmudunnabikajal/niftycli/issues"
  },
  "homepage": "https://niftycli.mahmudunnabikajal.com",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
